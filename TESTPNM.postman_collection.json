    {
      "name": "Upload Pet Image",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Response contains message or error\", function () {\r",
              "    var jsonData;\r",
              "    try {\r",
              "        jsonData = pm.response.json();\r",
              "        pm.expect(jsonData.message).to.include(\"uploaded\");\r",
              "    } catch(e) {\r",
              "        pm.expect(pm.response.text()).to.include(\"Exception\");\r",
